{
  "name": "Transparent Parliament Design System",
  "description": "Design tokens extracted from Storybook components for Figma import",
  "version": "1.0.0",
  "collections": {
    "Colors": {
      "modes": ["Default"],
      "variables": {
        "Background/Base": { "type": "COLOR", "value": "#0a0a0c" },
        "Background/Surface": { "type": "COLOR", "value": "#1a1a1e" },
        "Background/Elevated": { "type": "COLOR", "value": "#2a2a2e" },

        "Primary/500": { "type": "COLOR", "value": "#3b82f6" },
        "Primary/600": { "type": "COLOR", "value": "#2563eb" },
        "Primary/400": { "type": "COLOR", "value": "#60a5fa" },
        "Primary/Glow": { "type": "COLOR", "value": "rgba(59, 130, 246, 0.2)" },

        "Text/Primary": { "type": "COLOR", "value": "#ffffff" },
        "Text/Secondary": { "type": "COLOR", "value": "#9ca3af" },
        "Text/Muted": { "type": "COLOR", "value": "#6b7280" },

        "Status/Success": { "type": "COLOR", "value": "#22c55e" },
        "Status/Success-Muted": {
          "type": "COLOR",
          "value": "rgba(34, 197, 94, 0.1)"
        },
        "Status/Danger": { "type": "COLOR", "value": "#ef4444" },
        "Status/Danger-Muted": {
          "type": "COLOR",
          "value": "rgba(239, 68, 68, 0.2)"
        },
        "Status/Warning": { "type": "COLOR", "value": "#eab308" },

        "Glass/Background": {
          "type": "COLOR",
          "value": "rgba(255, 255, 255, 0.05)"
        },
        "Glass/Border": {
          "type": "COLOR",
          "value": "rgba(255, 255, 255, 0.1)"
        },
        "Glass/Hover": { "type": "COLOR", "value": "rgba(255, 255, 255, 0.1)" },

        "Party/Tevynes-Sajunga": { "type": "COLOR", "value": "#3b82f6" },
        "Party/Socialdemokratai": { "type": "COLOR", "value": "#ef4444" },
        "Party/Liberalai": { "type": "COLOR", "value": "#eab308" },
        "Party/Vardan-Lietuvos": { "type": "COLOR", "value": "#22c55e" },
        "Party/Valstiečiai": { "type": "COLOR", "value": "#059669" },
        "Party/Laisves-Partija": { "type": "COLOR", "value": "#ec4899" },
        "Party/Darbo-Partija": { "type": "COLOR", "value": "#f97316" },
        "Party/Default": { "type": "COLOR", "value": "#6b7280" }
      }
    },
    "Typography": {
      "modes": ["Default"],
      "variables": {
        "Font-Family/Primary": {
          "type": "STRING",
          "value": "system-ui, -apple-system, sans-serif"
        },

        "Font-Size/xs": { "type": "FLOAT", "value": 12 },
        "Font-Size/sm": { "type": "FLOAT", "value": 14 },
        "Font-Size/base": { "type": "FLOAT", "value": 16 },
        "Font-Size/lg": { "type": "FLOAT", "value": 18 },
        "Font-Size/xl": { "type": "FLOAT", "value": 20 },
        "Font-Size/2xl": { "type": "FLOAT", "value": 24 },
        "Font-Size/3xl": { "type": "FLOAT", "value": 30 },
        "Font-Size/4xl": { "type": "FLOAT", "value": 36 },

        "Font-Weight/Normal": { "type": "FLOAT", "value": 400 },
        "Font-Weight/Medium": { "type": "FLOAT", "value": 500 },
        "Font-Weight/Semibold": { "type": "FLOAT", "value": 600 },
        "Font-Weight/Bold": { "type": "FLOAT", "value": 700 },

        "Line-Height/Tight": { "type": "FLOAT", "value": 1.25 },
        "Line-Height/Normal": { "type": "FLOAT", "value": 1.5 },
        "Line-Height/Relaxed": { "type": "FLOAT", "value": 1.75 }
      }
    },
    "Spacing": {
      "modes": ["Default"],
      "variables": {
        "Space/0": { "type": "FLOAT", "value": 0 },
        "Space/0.5": { "type": "FLOAT", "value": 2 },
        "Space/1": { "type": "FLOAT", "value": 4 },
        "Space/1.5": { "type": "FLOAT", "value": 6 },
        "Space/2": { "type": "FLOAT", "value": 8 },
        "Space/3": { "type": "FLOAT", "value": 12 },
        "Space/4": { "type": "FLOAT", "value": 16 },
        "Space/5": { "type": "FLOAT", "value": 20 },
        "Space/6": { "type": "FLOAT", "value": 24 },
        "Space/8": { "type": "FLOAT", "value": 32 },
        "Space/10": { "type": "FLOAT", "value": 40 },
        "Space/12": { "type": "FLOAT", "value": 48 }
      }
    },
    "Radius": {
      "modes": ["Default"],
      "variables": {
        "Radius/None": { "type": "FLOAT", "value": 0 },
        "Radius/sm": { "type": "FLOAT", "value": 4 },
        "Radius/md": { "type": "FLOAT", "value": 6 },
        "Radius/lg": { "type": "FLOAT", "value": 8 },
        "Radius/xl": { "type": "FLOAT", "value": 12 },
        "Radius/2xl": { "type": "FLOAT", "value": 16 },
        "Radius/Full": { "type": "FLOAT", "value": 9999 }
      }
    },
    "Effects": {
      "modes": ["Default"],
      "variables": {
        "Shadow/sm": {
          "type": "STRING",
          "value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
        },
        "Shadow/md": {
          "type": "STRING",
          "value": "0 4px 6px -1px rgba(0, 0, 0, 0.1)"
        },
        "Shadow/lg": {
          "type": "STRING",
          "value": "0 10px 15px -3px rgba(0, 0, 0, 0.1)"
        },
        "Shadow/Glow-Blue": {
          "type": "STRING",
          "value": "0 0 15px rgba(59, 130, 246, 0.15)"
        },

        "Blur/sm": { "type": "FLOAT", "value": 4 },
        "Blur/md": { "type": "FLOAT", "value": 8 },
        "Blur/lg": { "type": "FLOAT", "value": 16 },
        "Blur/2xl": { "type": "FLOAT", "value": 40 }
      }
    }
  },
  "components": {
    "Button": {
      "variants": ["primary", "secondary", "ghost", "danger"],
      "sizes": ["sm", "md", "lg"],
      "storybook": "src/stories/Button.stories.tsx"
    },
    "Card": {
      "variants": ["default", "hover", "glow"],
      "storybook": "src/stories/Card.stories.tsx"
    },
    "Header": {
      "storybook": "src/stories/Header.stories.tsx"
    },
    "MpCard": {
      "storybook": "src/stories/MpCard.stories.tsx"
    },
    "StatCard": {
      "storybook": "src/stories/StatCard.stories.tsx"
    }
  }
}
